# Frontend Environment Variables

# Backend API URL (required)
NEXT_PUBLIC_API_URL=https://backend-arcanaai.nguyenvanloc.com

# Environment (optional)
NODE_ENV=development

# Adsterra ad network — copy the Direct Link URL from your Adsterra dashboard
# (Site → ad zone → Get Code → Direct Link). Leave empty to run in dev/test mode
# (countdown works but no real ad is shown and no impressions are recorded).
NEXT_PUBLIC_ADSTERRA_DIRECT_LINK_URL=

# Note: Payment configuration is handled on the backend
# See ../backend/.env.example for Lemon Squeezy and MetaMask settings
