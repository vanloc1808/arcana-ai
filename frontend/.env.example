# Frontend Environment Variables

# Backend API URL (required)
NEXT_PUBLIC_API_URL=https://backend-arcanaai.nguyenvanloc.com

# Environment (optional)
NODE_ENV=development

# Adsterra ad network — copy the invoke.js URL from your Adsterra Banner ad zone
# (Site → Banner zone → Get Code → the src of the second <script> tag).
# Leave empty to run in dev/test mode (countdown works, no ad is shown).
NEXT_PUBLIC_ADSTERRA_BANNER_INVOKE_URL=

# Note: Payment configuration is handled on the backend
# See ../backend/.env.example for Lemon Squeezy and MetaMask settings
