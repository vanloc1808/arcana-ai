# Copy this file to synthetic-traffic/.env and fill in real credentials locally.
# The real .env file is ignored by Git and excluded from the Docker build context.

ARCANA_SYNTHETIC_BASE_URL=http://tarot-backend:8000
ARCANA_SYNTHETIC_USERNAME=
ARCANA_SYNTHETIC_PASSWORD=

# Dashboard background traffic runs at 00:00, 06:00, 12:00, and 18:00 UTC.
ARCANA_SYNTHETIC_CRON=0 0,6,12,18 * * *
ARCANA_SYNTHETIC_RUN_ON_START=false

# OpenAI-backed chat message traffic runs hourly by default.
ARCANA_SYNTHETIC_MESSAGE_CRON=0 * * * *
ARCANA_SYNTHETIC_MESSAGE_RUN_ON_START=false

# Non-OpenAI dashboard traffic.
ARCANA_SYNTHETIC_HEALTH_REQUESTS=1000
ARCANA_SYNTHETIC_HEALTH_CONCURRENCY=50

# POST /chat/sessions/{session_id}/messages/ traffic that triggers OpenAI calls.
ARCANA_SYNTHETIC_MESSAGE_REQUESTS=2
ARCANA_SYNTHETIC_MESSAGE_DELAY_SECONDS=5
ARCANA_SYNTHETIC_REQUEST_TIMEOUT_SECONDS=240
